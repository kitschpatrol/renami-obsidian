{
	"name": "renami-obsidian",
	"version": "0.1.1",
	"private": true,
	"description": "An Obsidian plugin for content-aware automatic note name management.",
	"keywords": [
		"obsidian",
		"obsidian-md",
		"obsidian-plugin",
		"filenames",
		"frontmatter",
		"markdown"
	],
	"homepage": "https://github.com/kitschpatrol/renami-obsidian",
	"bugs": "https://github.com/kitschpatrol/renami-obsidian/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/renami-obsidian.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"main": "./dist/main.js",
	"scripts": {
		"build": "rimraf ./dist && tsc -noEmit -skipLibCheck && pnpm manifest && tsx ./scripts/build.ts production ",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "rimraf ./dist && pnpm manifest && tsx ./scripts/build.ts",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"manifest": "tsx ./scripts/generate-manifest.ts",
		"release": "pnpm manifest && bumpp package.json manifest.json --commit 'Release: %s' --tag '%s'",
		"renami:local-deploy": "shx cp -r ./dist/* ~/Notes/Vault/.obsidian/plugins/renami",
		"renami:use-local": "pnpm remove @kitschpatrol/renami && pnpm add -D ../renami",
		"renami:use-npm": "pnpm remove @kitschpatrol/renami && pnpm add -D @kitschpatrol/renami",
		"test": "echo \"No tests specified\" && exit 0"
	},
	"devDependencies": {
		"@kitschpatrol/renami": "^0.2.0",
		"@kitschpatrol/shared-config": "^7.6.2",
		"@types/node": "^20.19.41",
		"@types/sortablejs": "^1.15.9",
		"bumpp": "^11.1.0",
		"chokidar": "^5.0.0",
		"debounce": "^3.0.0",
		"esbuild": "^0.28.0",
		"esbuild-plugin-copy": "^2.1.1",
		"escape-string-regexp": "^5.0.0",
		"obsidian": "1.12.3",
		"obsidian-typings": "6.4.0",
		"plur": "^6.0.0",
		"rimraf": "^6.1.3",
		"shx": "^0.4.0",
		"sortablejs": "^1.15.7",
		"tslib": "^2.8.1",
		"tsx": "^4.22.1",
		"type-fest": "^5.6.0",
		"typescript": "~5.9.3"
	},
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.22.2"
		}
	},
	"obsidian": {
		"author": "Kitschpatrol",
		"description": "Content-aware automatic note file name management.",
		"id": "renami",
		"isDesktopOnly": true,
		"minAppVersion": "1.12.4",
		"name": "Renami"
	}
}
