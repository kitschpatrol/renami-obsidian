{
	"name": "renami-obsidian",
	"version": "0.0.0",
	"description": "An Obsidian plugin for content-aware automatic note name management.",
	"keywords": [
		"obsidian",
		"obsidian-md",
		"obsidian-plugin",
		"filenames",
		"frontmatter",
		"markdown"
	],
	"homepage": "https://github.com/kitschpatrol/renami-obsidian",
	"bugs": "https://github.com/kitschpatrol/renami-obsidian/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/renami-obsidian.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"main": "./dist/main.js",
	"scripts": {
		"build": "rimraf ./dist && tsc -noEmit -skipLibCheck && pnpm run manifest && tsx ./scripts/build.ts production ",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"dev": "rimraf ./dist && pnpm run manifest && tsx ./scripts/build.ts",
		"fix": "kpi fix",
		"lint": "kpi lint",
		"manifest": "tsx ./scripts/generate-manifest.ts",
		"release": "pnpm run manifest && bumpp package.json manifest.json --commit 'Release: %s' --tag '%s'",
		"renami:local-deploy": "cp -r ./dist/* ~/Notes/Vault/.obsidian/plugins/renami",
		"renami:use-local": "pnpm remove renami ; pnpm add -D ../renami",
		"renami:use-npm": "pnpm remove renami ; pnpm add -D renami"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.10.0",
		"@types/node": "^20.19.25",
		"@types/sortablejs": "^1.15.9",
		"bumpp": "^10.3.2",
		"chokidar": "^5.0.0",
		"debounce": "^3.0.0",
		"esbuild": "^0.27.1",
		"esbuild-plugin-copy": "^2.1.1",
		"escape-string-regexp": "^5.0.0",
		"obsidian": "1.10.0",
		"obsidian-typings": "4.58.0",
		"plur": "^6.0.0",
		"renami": "link:../renami",
		"rimraf": "^6.1.2",
		"sortablejs": "^1.15.6",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"type-fest": "^5.3.1",
		"typescript": "~5.9.3"
	},
	"packageManager": "pnpm@10.25.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"obsidian": {
		"author": "Kitschpatrol",
		"description": "Content-aware automatic note file name management.",
		"id": "renami",
		"isDesktopOnly": true,
		"minAppVersion": "1.9.14",
		"name": "Renami"
	}
}
